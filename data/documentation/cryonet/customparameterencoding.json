{"identifier":{"url":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CustomParameterEncoding","kind":"identifier"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"此结构体遵循 Alamofire 的 "},{"type":"codeVoice","code":"ParameterEncoding"},{"type":"text","text":" 协议，使得您可以将任何自定义的参数编码行为"},{"type":"text","text":" "},{"type":"text","text":"集成到 Alamofire 的请求流程中。这对于处理非标准或特定于业务的请求体格式非常有用。"}],"type":"paragraph"},{"text":"使用示例","anchor":"%E4%BD%BF%E7%94%A8%E7%A4%BA%E4%BE%8B","level":3,"type":"heading"},{"syntax":"swift","code":["\/\/ 示例：一个简单的自定义编码，将参数编码为 URL 查询字符串，即使是 POST 请求","let customURLEncoding = CustomParameterEncoding { urlRequest, parameters in","    var mutableRequest = try urlRequest.asURLRequest()","    guard let parameters = parameters else { return mutableRequest }","","    var urlComponents = URLComponents(url: mutableRequest.url!, resolvingAgainstBaseURL: false)","    urlComponents?.queryItems = parameters.map { URLQueryItem(name: $0.key, value: \"\\($0.value)\") }","    mutableRequest.url = urlComponents?.url","    return mutableRequest","}","","\/\/ 在请求中使用自定义编码","AF.request(\"https:\/\/api.example.com\/data\", method: .post, parameters: [\"id\": 123], encoding: customURLEncoding)","    .responseJSON { response in","        debugPrint(response)","    }"],"type":"codeListing"},{"content":[{"inlineContent":[{"text":"","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"encodingClosure"},{"text":" 闭包必须是 ","type":"text"},{"type":"codeVoice","code":"@Sendable"},{"text":" 的，以确保在并发环境中安全执行。","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"通常情况下，您会通过 "},{"type":"reference","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder\/custom(_:)","isActive":true},{"type":"text","text":" 枚举成员来使用此自定义编码。"}]}]}],"type":"unorderedList"}],"style":"note","name":"Note","type":"aside"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"isActive":true,"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder\/custom(_:)","type":"reference"}]}],"style":"note","name":"See Also","type":"aside"}]}],"topicSections":[{"generated":true,"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding\/init(encoding:)"]},{"generated":true,"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding\/encode(_:with:)"]}],"sections":[],"relationshipsSections":[{"title":"Conforms To","kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/cryonet.CryoNet\/9Alamofire17ParameterEncodingP","doc:\/\/cryonet.CryoNet\/s8SendableP"]}],"abstract":[{"type":"codeVoice","code":"CustomParameterEncoding"},{"text":" 允许您定义和使用自定义的参数编码逻辑。","type":"text"}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Structure","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"CustomParameterEncoding","kind":"identifier"}],"title":"CustomParameterEncoding","navigatorTitle":[{"text":"CustomParameterEncoding","kind":"identifier"}],"symbolKind":"struct","externalID":"s:7CryoNet23CustomParameterEncodingV","role":"symbol","modules":[{"name":"CryoNet"}]},"hierarchy":{"paths":[["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/d
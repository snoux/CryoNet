{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"CustomParameterEncoding"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"此结构体遵循 Alamofire 的 "},{"type":"codeVoice","code":"ParameterEncoding"},{"type":"text","text":" 协议，使得您可以将任何自定义的参数编码行为"},{"type":"text","text":" "},{"type":"text","text":"集成到 Alamofire 的请求流程中。这对于处理非标准或特定于业务的请求体格式非常有用。"}],"type":"paragraph"},{"type":"heading","anchor":"%E4%BD%BF%E7%94%A8%E7%A4%BA%E4%BE%8B","level":3,"text":"使用示例"},{"type":"codeListing","syntax":"swift","code":["\/\/ 示例：一个简单的自定义编码，将参数编码为 URL 查询字符串，即使是 POST 请求","let customURLEncoding = CustomParameterEncoding { urlRequest, parameters in","    var mutableRequest = try urlRequest.asURLRequest()","    guard let parameters = parameters else { return mutableRequest }","","    var urlComponents = URLComponents(url: mutableRequest.url!, resolvingAgainstBaseURL: false)","    urlComponents?.queryItems = parameters.map { URLQueryItem(name: $0.key, value: \"\\($0.value)\") }","    mutableRequest.url = urlComponents?.url","    return mutableRequest","}","","\/\/ 在请求中使用自定义编码","AF.request(\"https:\/\/api.example.com\/data\", method: .post, parameters: [\"id\": 123], encoding: customURLEncoding)","    .responseJSON { response in","        debugPrint(response)","    }"]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""}]},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"encodingClosure"},{"type":"text","text":" 闭包必须是 "},{"type":"codeVoice","code":"@Sendable"},{"type":"text","text":" 的，以确保在并发环境中安全执行。"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"通常情况下，您会通过 "},{"type":"reference","isActive":true,"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder\/custom(_:)"},{"type":"text","text":" 枚举成员来使用此自定义编码。"}]}]}],"type":"unorderedList"}],"style":"note","name":"Note"},{"type":"aside","content":[{"inlineContent":[{"text":"","type":"text"},{"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder\/custom(_:)","isActive":true,"type":"reference"}],"type":"paragraph"}],"style":"note","name":"See Also"}]}],"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding\/init(encoding:)"],"anchor":"Initializers"},{"title":"Instance Methods","generated":true,"identifiers":["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding\/encode(_:with:)"],"anchor":"Instance-Methods"}],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding","interfaceLanguage":"swift"},"metadata":{"externalID":"s:7CryoNet23CustomParameterEncodingV","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CustomParameterEncoding","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"CustomParameterEncoding"}],"symbolKind":"struct","modules":[{"name":"CryoNet"}],"roleHeading":"Structure","title":"CustomParameterEncoding"},"relationshipsSections":[{"title":"Conforms To","type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/cryonet.CryoNet\/9Alamofire17ParameterEncodingP","doc:\/\/cryonet.CryoNet\/s8SendableP"]}],"hierarchy":{"paths":[["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cryonet\/customparameterencoding"]}],"abstract":[{"type":"codeVoice","code":"CustomParameterEncoding"},{"type":"t
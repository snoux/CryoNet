{"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding\/init(encoding:)"],"anchor":"Initializers","generated":true},{"title":"Instance Methods","identifiers":["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding\/encode(_:with:)"],"anchor":"Instance-Methods","generated":true}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/cryonet.CryoNet\/9Alamofire17ParameterEncodingP","doc:\/\/cryonet.CryoNet\/s8SendableP"],"type":"conformsTo","kind":"relationships"}],"variants":[{"paths":["\/documentation\/cryonet\/customparameterencoding"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"navigatorTitle":[{"text":"CustomParameterEncoding","kind":"identifier"}],"title":"CustomParameterEncoding","roleHeading":"Structure","modules":[{"name":"CryoNet"}],"role":"symbol","symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CustomParameterEncoding","kind":"identifier"}],"externalID":"s:7CryoNet23CustomParameterEncodingV"},"hierarchy":{"paths":[["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"abstract":[{"code":"CustomParameterEncoding","type":"codeVoice"},{"type":"text","text":" 允许您定义和使用自定义的参数编码逻辑。"}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CustomParameterEncoding","kind":"identifier"}],"platforms":["iOS"],"languages":["swift"]}]},{"content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"此结构体遵循 Alamofire 的 "},{"code":"ParameterEncoding","type":"codeVoice"},{"type":"text","text":" 协议，使得您可以将任何自定义的参数编码行为"},{"type":"text","text":" "},{"type":"text","text":"集成到 Alamofire 的请求流程中。这对于处理非标准或特定于业务的请求体格式非常有用。"}],"type":"paragraph"},{"anchor":"%E4%BD%BF%E7%94%A8%E7%A4%BA%E4%BE%8B","level":3,"text":"使用示例","type":"heading"},{"syntax":"swift","code":["\/\/ 示例：一个简单的自定义编码，将参数编码为 URL 查询字符串，即使是 POST 请求","let customURLEncoding = CustomParameterEncoding { urlRequest, parameters in","    var mutableRequest = try urlRequest.asURLRequest()","    guard let parameters = parameters else { return mutableRequest }","","    var urlComponents = URLComponents(url: mutableRequest.url!, resolvingAgainstBaseURL: false)","    urlComponents?.queryItems = parameters.map { URLQueryItem(name: $0.key, value: \"\\($0.value)\") }","    mutableRequest.url = urlComponents?.url","    return mutableRequest","}","","\/\/ 在请求中使用自定义编码","AF.request(\"https:\/\/api.example.com\/data\", method: .post, parameters: [\"id\": 123], encoding: customURLEncoding)","    .responseJSON { response in","        debugPrint(response)","    }"],"type":"codeListing"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"encodingClosure"},{"type":"text","text":" 闭包必须是 "},{"type":"codeVoice","code":"@Sendable"},{"type":"text","text":" 的，以确保在并发环境中安全执行。"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"通常情况下，您会通过 ","type":"text"},{"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder\/custom(_:)","type":"reference","isActive":true},{"text":" 枚举成员来使用此自定义编码。","type":"text"}],"type":"paragraph"}]}]}],"type":"aside"},{"style":"note","name":"See Also","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"reference","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder","isActive":true},{"text":", ","type":"text"},{"type":"reference","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder\/custom(_:)","isActive":true}]}],"type":"aside"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/cryonet.CryoNet\
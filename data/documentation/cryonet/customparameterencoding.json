nse in","        debugPrint(response)","    }"],"syntax":"swift","type":"codeListing"},{"style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":""}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"encodingClosure"},{"type":"text","text":" 闭包必须是 "},{"type":"codeVoice","code":"@Sendable"},{"type":"text","text":" 的，以确保在并发环境中安全执行。"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"通常情况下，您会通过 "},{"type":"reference","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder\/custom(_:)","isActive":true},{"type":"text","text":" 枚举成员来使用此自定义编码。"}]}]}],"type":"unorderedList"}],"type":"aside"},{"style":"note","name":"See Also","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"reference","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder","isActive":true},{"text":", ","type":"text"},{"type":"reference","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder\/custom(_:)","isActive":true}]}],"type":"aside"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cryonet\/customparameterencoding"]}],"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CustomParameterEncoding","kind":"identifier"}],"roleHeading":"Structure","externalID":"s:7CryoNet23CustomParameterEncodingV","title":"CustomParameterEncoding","modules":[{"name":"CryoNet"}],"symbolKind":"struct","role":"symbol","navigatorTitle":[{"text":"CustomParameterEncoding","kind":"identifier"}]},"relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/cryonet.CryoNet\/9Alamofire17ParameterEncodingP","doc:\/\/cryonet.CryoNet\/s8SendableP"],"type":"conformsTo"}],"hierarchy":{"paths":[["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet"]]},"abstract":[{"code":"CustomParameterEncoding","type":"codeVoic
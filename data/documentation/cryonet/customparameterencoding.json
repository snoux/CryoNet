{"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"roleHeading":"Structure","title":"CustomParameterEncoding","symbolKind":"struct","role":"symbol","modules":[{"name":"CryoNet"}],"externalID":"s:7CryoNet23CustomParameterEncodingV","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CustomParameterEncoding","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"CustomParameterEncoding"}]},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding\/init(encoding:)"],"anchor":"Initializers","generated":true},{"title":"Instance Methods","identifiers":["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding\/encode(_:with:)"],"anchor":"Instance-Methods","generated":true}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/cryonet.CryoNet\/9Alamofire17ParameterEncodingP","doc:\/\/cryonet.CryoNet\/s8SendableP"],"type":"conformsTo","kind":"relationships"}],"kind":"symbol","identifier":{"url":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cryonet\/customparameterencoding"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CustomParameterEncoding","kind":"identifier"}],"platforms":["iOS"]}]},{"content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"text":"此结构体遵循 Alamofire 的 ","type":"text"},{"code":"ParameterEncoding","type":"codeVoice"},{"text":" 协议，使得您可以将任何自定义的参数编码行为","type":"text"},{"text":" ","type":"text"},{"text":"集成到 Alamofire 的请求流程中。这对于处理非标准或特定于业务的请求体格式非常有用。","type":"text"}],"type":"paragraph"},{"anchor":"%E4%BD%BF%E7%94%A8%E7%A4%BA%E4%BE%8B","level":3,"type":"heading","text":"使用示例"},{"type":"codeListing","syntax":"swift","code":["\/\/ 示例：一个简单的自定义编码，将参数编码为 URL 查询字符串，即使是 POST 请求","let customURLEncoding = CustomParameterEncoding { urlRequest, parameters in","    var mutableRequest = try urlRequest.asURLRequest()","    guard let parameters = parameters else { return mutableRequest }","","    var urlComponents = URLComponents(url: mutableRequest.url!, resolvingAgainstBaseURL: false)","    urlComponents?.queryItems = parameters.map { URLQueryItem(name: $0.key, value: \"\\($0.value)\") }","    mutableRequest.url = urlComponents?.url","    return mutableRequest","}","","\/\/ 在请求中使用自定义编码","AF.request(\"https:\/\/api.example.com\/data\", method: .post, parameters: [\"id\": 123], encoding: customURLEncoding)","    .responseJSON { response in","        debugPrint(response)","    }"]},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"encodingClosure","type":"codeVoice"},{"text":" 闭包必须是 ","type":"text"},{"code":"@Sendable","type":"codeVoice"},{"text":" 的，以确保在并发环境中安全执行。","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"通常情况下，您会通过 ","type":"text"},{"type":"reference","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder\/custom(_:)","isActive":true},{"text":" 枚举成员来使用此自定义编码。","type":"text"}]}]}]}]},{"style":"note","name":"See Also","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"isActive":true,"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder\/custom(_:)","type":"reference"}]}]}],"kind":"content"}],"abstract":[{"type":"codeVoice","code":"CustomParameterEncoding"},{"type":"text","text":" 允许您定义和使用自定义的参数编码逻辑。"}],"references":{"doc://cryonet.CryoNet/documentation/CryoNet/CustomParameterEncoding/init(encoding:)":{"abstract":[{"text":"初始化 ","type":"text"},{"type":"codeVoice","code":"CustomParameterEncoding"},{"text":" 实例。","type":"text"}],"url":"\/documentation\/cryonet\/customparameterencoding\/init(encoding:)","kind":"symbol","type":"topic","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding\/init(encoding:)","title":"init(encoding:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"encoding"},{"kind":"text","text":": ("},{"kind":"keyword","text":"any"},{"kind":"text","text":" "},{"preciseIdentifier":"s:9Alamofire21URLRequestConvertibleP","kind":"typeIdentifier","text":"URLRequestConvertible"},{"kind":"text","text":", "},{"preciseIdentifier":"s:9Alamofire10Parametersa","kind":"typeIdentifier","text":"Parameters"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:10Foundation10URLRequestV","kind":"typeIdentifier","text":"URLRequest"},{"kind":"text","text":")"}],"role":"symbol"},"doc://cryonet.CryoNet/documentation/CryoNet/CustomParameterEncoding":{"abstract":[{"type":"codeVoice","code":"CustomParameterEncoding"},{"text":" 允许您定义和使用自定义的参数编码逻辑。","type":"text"}],"navigatorTitle":[{"text":"CustomParameterEncoding","kind":"identifier"}],"type":"topic","kind":"symbol","url":"\/documentation\/cryonet\/customparameterencoding","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CustomParameterEncoding","kind":"identifier"}],"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding","title":"CustomParameterEncoding"},"doc://cryonet.CryoNet/9Alamofire17ParameterEncodingP":{"identifier":"doc:\/\/cryonet.CryoNet\/9Alamofire17ParameterEncodingP","type":"unresolvable","title":"Alamofire.ParameterEncoding"}
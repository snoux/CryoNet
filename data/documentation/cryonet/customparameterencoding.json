{"schemaVersion":{"major":0,"patch":0,"minor":3},"relationshipsSections":[{"identifiers":["doc:\/\/cryonet.CryoNet\/9Alamofire17ParameterEncodingP","doc:\/\/cryonet.CryoNet\/s8SendableP"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"sections":[],"abstract":[{"code":"CustomParameterEncoding","type":"codeVoice"},{"type":"text","text":" 允许您定义和使用自定义的参数编码逻辑。"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"CustomParameterEncoding"}],"languages":["swift"],"platforms":["iOS"]}]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"此结构体遵循 Alamofire 的 ","type":"text"},{"code":"ParameterEncoding","type":"codeVoice"},{"text":" 协议，使得您可以将任何自定义的参数编码行为","type":"text"},{"text":" ","type":"text"},{"text":"集成到 Alamofire 的请求流程中。这对于处理非标准或特定于业务的请求体格式非常有用。","type":"text"}],"type":"paragraph"},{"anchor":"%E4%BD%BF%E7%94%A8%E7%A4%BA%E4%BE%8B","text":"使用示例","type":"heading","level":3},{"syntax":"swift","type":"codeListing","code":["\/\/ 示例：一个简单的自定义编码，将参数编码为 URL 查询字符串，即使是 POST 请求","let customURLEncoding = CustomParameterEncoding { urlRequest, parameters in","    var mutableRequest = try urlRequest.asURLRequest()","    guard let parameters = parameters else { return mutableRequest }","","    var urlComponents = URLComponents(url: mutableRequest.url!, resolvingAgainstBaseURL: false)","    urlComponents?.queryItems = parameters.map { URLQueryItem(name: $0.key, value: \"\\($0.value)\") }","    mutableRequest.url = urlComponents?.url","    return mutableRequest","}","","\/\/ 在请求中使用自定义编码","AF.request(\"https:\/\/api.example.com\/data\", method: .post, parameters: [\"id\": 123], encoding: customURLEncoding)","    .responseJSON { response in","        debugPrint(response)","    }"]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"encodingClosure"},{"type":"text","text":" 闭包必须是 "},{"type":"codeVoice","code":"@Sendable"},{"type":"text","text":" 的，以确保在并发环境中安全执行。"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"通常情况下，您会通过 "},{"isActive":true,"type":"reference","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder\/custom(_:)"},{"type":"text","text":" 枚举成员来使用此自定义编码。"}]}]}]}],"name":"Note","type":"aside"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder","type":"reference","isActive":true},{"text":", ","type":"text"},{"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CryoParameterEncoder\/custom(_:)","type":"reference","isActive":true}]}],"name":"See Also","type":"aside"}]}],"hierarchy":{"paths":[["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding"},"topicSections":[{"identifiers":["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding\/init(encoding:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"identifiers":["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/CustomParameterEncoding\/encode(_:with:)"],"generated":true,"title":"Instance Methods","anchor":"Instance-Methods"}],"metadata":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"CustomParameterEncoding"}],"roleHeading":"Structure","symbolKind":"struct","title":"CustomParameterEncoding","externalID":"s:7CryoNet23CustomParameterEncodingV","modules":[{"name":"CryoNet"}],"navigatorTitle":[{"kind":"identifier","text":"CustomParameterEncoding"}],"role":"symbol"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cr
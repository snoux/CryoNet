{"metadata":{"modules":[{"name":"CryoNet"}],"externalID":"s:7CryoNet13UploadManagerC","symbolKind":"class","fragments":[{"text":"actor","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UploadManager","kind":"identifier"}],"roleHeading":"Class","title":"UploadManager","role":"symbol","navigatorTitle":[{"text":"UploadManager","kind":"identifier"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet"]]},"sections":[],"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/cryonet.CryoNet\/s8SendableP","doc:\/\/cryonet.CryoNet\/ScA"],"kind":"relationships","title":"Conforms To"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"actor"},{"kind":"text","text":" "},{"kind":"identifier","text":"UploadManager"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Model"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Model"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"JSONParseable","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/JSONParseable","preciseIdentifier":"s:7CryoNet13JSONParseableP"}],"languages":["swift"],"platforms":["iOS"]}]},{"content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"支持本地文件和二进制内存数据上传；"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"支持全局和任务级别表单参数（全局参数可被任务参数覆盖）；"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"支持多文件合并为一个任务，文件和参数一同拼接到 multipart\/form-data；","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"支持任务进度、队列\/并发控制、暂停\/恢复\/取消\/删除等操作；","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"泛型响应类型，自动解析响应为你的自定义模型；","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"需要准确判断上传结果(成功或失败),必须传入自定义拦截器，且该拦截器继承自"},{"type":"codeVoice","code":"DefaultInterceptor"},{"type":"text","text":"，并配置好响应数据结构（见下方示例）。"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"泛型"},{"type":"codeVoice","code":"Model"},{"type":"text","text":"必须实现"},{"type":"codeVoice","code":"JSONParseable"},{"type":"text","text":"协议，见下方示例。"}]}]}]}],"type":"aside","name":"Note"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"reference","isActive":true,"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/UploadFileItem"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/UploadTask"},{"type":"text","text":", "},{"type":"codeVoice","code":"UploadManagerDelegate"}]}],"type":"aside","name":"See Also"},{"anchor":"%E9%85%8D%E7%BD%AE%E6%8B%A6%E6%88%AA%E5%99%A8%E5%92%8C%E5%93%8D%E5%BA%94%E7%BB%93%E6%9E%84%E7%A4%BA%E4%BE%8B","level":3,"text":"配置拦截器和响应结构示例","type":"heading"},{"code":["\/\/ 自定义拦截器，必须继承 DefaultInterceptor","class UploadInterceptor: DefaultInterceptor, @unchecked Sendable {","    init(){","        let responseConfig = UploadResponseConfig()","        super.init(responseConfig: responseConfig)  \/\/ 配置响应结构","    }","}","","\/\/ 配置响应结构（支持深层数据）","final class UploadResponseConfig: DefaultResponseStructure, @unchecked Sendable {","    override func extractData(from json: JSON, originalData: Data) -> Result<Data, any Error> {","        let targetData = json[\"data\"]","        if !targetData.exists() || targetData.type == .null { return .success(originalData) }","        do {","            let validData: Data = try targetData.rawData()","            return .success(validData)","        } catch {","            return .failure(error)","        }","    }","    override func extractFailureReason(from json: JSON, originalData: Data) -> String? {","        json[\"success\"].string","    }","    override func isSuccess(json: JSON) -> Bool {","        return json[\"status\"].intValue == 200","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"%E6%B3%9B%E5%9E%8B%E5%93%8D%E5%BA%94%E6%A8%A1%E5%9E%8B%E7%A4%BA%E4%BE%8B","level":3,"text":"泛型响应模型示例","type":"heading"},{"code":["class UploadModel: JSONParseable {","    var url_viewer: String = \"\"","    var display_url: String = \"\"","    let id = UUID()","    required init?(json: JSON) {","        url_viewer = json.string(\"url_viewer\", defaultValue: \"\")","        display_url = json.string(\"display_url\", defaultValue: \"\")","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"%E4%BD%BF%E7%94%A8%E7%A4%BA%E4%BE%8B","level":3,"text":"使用示例","type":"heading"},{"code":["let uploadManager = UploadManager<UploadModel>(","    uploadURL: URL(string: \"https:\/\/api.imgbb.com\/1\/upload\")!,","    parameters: [\"key\": \"xxx\"],","    maxConcurrentUploads: 3,","    interceptor: UploadInterceptor()",")","","let fileItem = UploadFileItem(data: imageData, name: \"image\", fileName: \"photo.jpg\", mimeType: \"image\/jpeg\")","let taskID = await uploadManager.addTask(files: [fileItem])","await uploadManager.startTask(id: taskID)"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"abstract":[{"type":"text","text":"批量\/单任务上传管理器（支持泛型模型响应）"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/UploadManager"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/cryonet\/uploadmanager"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"generated":true,"identifiers":["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/UploadManager\/init(identifier:uploadURL:parameters:headers:maxConcurrentUploads:interceptor:tokenManager:)"],"anchor":"Initializers","title":"Initializers"},{"generated":true,"identifiers":["doc:\/\/cryo
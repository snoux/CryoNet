xternalID":"s:7CryoNet13UploadManagerC","navigatorTitle":[{"text":"UploadManager","kind":"identifier"}],"modules":[{"name":"CryoNet"}]},"relationshipsSections":[{"identifiers":["doc:\/\/cryonet.CryoNet\/s8SendableP","doc:\/\/cryonet.CryoNet\/ScA"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"actor","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UploadManager","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Model","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Model","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"JSONParseable","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/JSONParseable","preciseIdentifier":"s:7CryoNet13JSONParseableP","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["iOS"]}]},{"content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"支持本地文件和二进制内存数据上传；"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"支持全局和任务级别表单参数（全局参数可被任务参数覆盖）；"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"支持多文件合并为一个任务，文件和参数一同拼接到 multipart\/form-data；","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"支持任务进度、队列\/并发控制、暂停\/恢复\/取消\/删除等操作；","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"泛型响应类型，自动解析响应为你的自定义模型；"}],"type":"paragraph"}]}],"type":"orderedList"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"需要准确判断上传结果(成功或失败),必须传入自定义拦截器，且该拦截器继承自"},{"code":"DefaultInterceptor","type":"codeVoice"},{"type":"text","text":"，并配置好响应数据结构（见下方示例）。"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"泛型","type":"text"},{"type":"codeVoice","code":"Model"},{"text":"必须实现","type":"text"},{"type":"codeVoice","code":"JSONParseable"},{"text":"协议，见下方示例。","type":"text"}]}]}],"type":"unorderedList"}],"style":"note","type":"aside"},{"name":"See Also","content":[{"inlineContent":[{"text":"","type":"text"},{"isActive":true,"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/UploadFileItem","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/UploadTask","type":"reference"},{"text":", ","type":"text"},{"type":"codeVoice","code":"UploadManagerDelegate"}],"type":"paragraph"}],"style":"note","type":"aside"},{"text":"配置拦截器和响应结构示例","level":3,"anchor":"%E9%85%8D%E7%BD%AE%E6%8B%A6%E6%88%AA%E5%99%A8%E5%92%8C%E5%93%8D%E5%BA%94%E7%BB%93%E6%9E%84%E7%A4%BA%E4%BE%8B","type":"heading"},{"syntax":"swift","code":["\/\/ 自定义拦截器，必须继承 DefaultInterceptor","class UploadInterceptor: DefaultInterceptor, @unchecked Sendable {","    init(){","        let responseConfig = UploadResponseConfig()","        super.init(responseConfig: responseConfig)  \/\/ 配置响应结构","    }","}","","\/\/ 配置响应结构（支持深层数据）","final class UploadResponseConfig: DefaultResponseStructure, @unchecked Sendable {","    override func extractData(from json: JSON, originalData: Data) -> Result<Data, any Error> {","        let targetData = json[\"data\"]","        if !targetData.exists() || targetData.type == .null { return .success(originalData) }","        do {","            let validData: Data = try targetData.rawData()","            return .success(validData)","        } catch {","            return .failure(error)","        }","    }","    override func extractFailureReason(from json: JSON, originalData: Data) -> String? {","        json[\"success\"].string","    }","    override func isSuccess(json: JSON) -> Bool {","        return json[\"status\"].intValue == 200","    }","}"],"type":"codeListing"},{"text":"泛型响应模型示例","level":3,"anchor":"%E6%B3%9B%E5%9E%8B%E5%93%8D%E5%BA%94%E6%A8%A1%E5%9E%8B%E7%A4%BA%E4%BE%8B","type":"heading"},{"syntax":"swift","code":["class UploadModel: JSONParseable {","    var url_viewer: String = \"\"","    var display_url: String = \"\"","    let id = UUID()","    required init?(json: JSON) {","        url_viewer = json.string(\"url_viewer\", defaultValue: \"\")","        display_url = json.string(\"display_url\", defaultValue: \"\")","    }","}"],"type":"codeListing"},{"text":"使用示例","level":3,"anchor":"%E4%BD%BF%E7%94%A8%E7%A4%BA%E4%BE%8B","type":"heading"},{"syntax":"swift","code":["let uploadManager = UploadManager<UploadModel>(","    uploadURL: URL(string: \"https:\/\/api.imgbb.com\/1\/upload\")!,","    parameters: [\"key\": \"xxx\"],","    maxConcurrentUploads: 3,","    interceptor: UploadInterceptor()",")","","let fileItem = UploadFileItem(data: imageData, name: \"image\", fileName: \"photo.jpg\", mimeType: \"image\/jpeg\")","let taskID = await uploadManager.addTask(files: [fileItem])","await uploadManager.startTask(id: taskID)"],"type":"codeListing"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/cryonet\/uploadmanager"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://cryonet.CryoNet/documentation/CryoNet/UploadManager/parameters":{"url":"\/documentation\/cryonet\/uploadmanager\/parameters","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"parameters","kind":"identifier"},{"text":": [","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":"]?","kind":"text"}],"abstract":[{"text":"全局表单参数","type":"text"}],"title":"parameters","kind":"symbol","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/UploadManager\/parameters","role":"symbol","type":"topic"},"doc://cryonet.CryoNet/documentation/CryoNet/UploadManager/addTask(files:)":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/UploadManager\/addTask(file
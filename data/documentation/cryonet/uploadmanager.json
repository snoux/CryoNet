d"},{"text":" ","kind":"text"},{"text":"UploadManager","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Model","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Model","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/JSONParseable","text":"JSONParseable","kind":"typeIdentifier","preciseIdentifier":"s:7CryoNet13JSONParseableP"}],"platforms":["iOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"支持本地文件和二进制内存数据上传；","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"支持全局和任务级别表单参数（全局参数可被任务参数覆盖）；","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"支持多文件合并为一个任务，文件和参数一同拼接到 multipart\/form-data；"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"支持任务进度、队列\/并发控制、暂停\/恢复\/取消\/删除等操作；"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"泛型响应类型，自动解析响应为你的自定义模型；"}],"type":"paragraph"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"需要准确判断上传结果(成功或失败),必须传入自定义拦截器，且该拦截器继承自","type":"text"},{"code":"DefaultInterceptor","type":"codeVoice"},{"text":"，并配置好响应数据结构（见下方示例）。","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"泛型","type":"text"},{"code":"Model","type":"codeVoice"},{"text":"必须实现","type":"text"},{"code":"JSONParseable","type":"codeVoice"},{"text":"协议，见下方示例。","type":"text"}]}]}]}],"type":"aside","style":"note","name":"Note"},{"content":[{"inlineContent":[{"type":"text","text":""},{"isActive":true,"type":"reference","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/UploadFileItem"},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/UploadTask"},{"type":"text","text":", "},{"type":"codeVoice","code":"UploadManagerDelegate"}],"type":"paragraph"}],"type":"aside","style":"note","name":"See Also"},{"type":"heading","level":3,"text":"配置拦截器和响应结构示例","anchor":"%E9%85%8D%E7%BD%AE%E6%8B%A6%E6%88%AA%E5%99%A8%E5%92%8C%E5%93%8D%E5%BA%94%E7%BB%93%E6%9E%84%E7%A4%BA%E4%BE%8B"},{"code":["\/\/ 自定义拦截器，必须继承 DefaultInterceptor","class UploadInterceptor: DefaultInterceptor, @unchecked Sendable {","    init(){","        let responseConfig = UploadResponseConfig()","        super.init(responseConfig: responseConfig)  \/\/ 配置响应结构","    }","}","","\/\/ 配置响应结构（支持深层数据）","final class UploadResponseConfig: DefaultResponseStructure, @unchecked Sendable {","    override func extractData(from json: JSON, originalData: Data) -> Result<Data, any Error> {","        let targetData = json[\"data\"]","        if !targetData.exists() || targetData.type == .null { return .success(originalData) }","        do {","            let validData: Data = try targetData.rawData()","            return .success(validData)","        } catch {","            return .failure(error)","        }","    }","    override func extractFailureReason(from json: JSON, originalData: Data) -> String? {","        json[\"success\"].string","    }","    override func isSuccess(json: JSON) -> Bool {","        return json[\"status\"].intValue == 200","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"text":"泛型响应模型示例","anchor":"%E6%B3%9B%E5%9E%8B%E5%93%8D%E5%BA%94%E6%A8%A1%E5%9E%8B%E7%A4%BA%E4%BE%8B"},{"code":["class UploadModel: JSONParseable {","    var url_viewer: String = \"\"","    var display_url: String = \"\"","    let id = UUID()","    required init?(json: JSON) {","        url_viewer = json.string(\"url_viewer\", defaultValue: \"\")","        display_url = json.string(\"display_url\", defaultValue: \"\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"text":"使用示例","anchor":"%E4%BD%BF%E7%94%A8%E7%A4%BA%E4%BE%8B"},{"code":["let uploadManager = UploadManager<UploadModel>(","    uploadURL: URL(string: \"https:\/\/api.imgbb.com\/1\/upload\")!,","    parameters: [\"key\": \"xxx\"],","    maxConcurrentUploads: 3,","    interceptor: UploadInterceptor()",")","","let fileItem = UploadFileItem(data: imageData, name: \"image\", fileName: \"photo.jpg\", mimeType: \"image\/jpeg\")","let taskID = await uploadManager.addTask(files: [fileItem])","await uploadManager.startTask(id: taskID)"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"sections":[],"metadata":{"symbolKind":"class","externalID":"s:7CryoNet13UploadManagerC","navigatorTitle":[{"text":"UploadManager","kind":"identifier"}],"roleHeading":"Class","role":"symbol","fragments":[{"text":"actor","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UploadManager","kind":"identifier"}],"title":"UploadManager","modules":[{"name":"CryoNet"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://cryonet.CryoNet/documentation/CryoNet/UploadManager/uploadURL":{"kind":"symbol","abstract":[{"type":"text","text":"全局上传API接口URL"}],"type":"topic","url":"\/documentation\/cryonet\/uploadmanager\/uploadurl","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/UploadManager\/uploadURL","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"uploadURL","kind":"identifier"},{"text":": ","kind":"text"},{"text":"URL","preciseIdentifier":"s:10Foundation3URLV","kind":"typeIdentifier"}],"title":"uploadURL"},"doc://cryonet.CryoNet/documentation/CryoNet/UploadManager/batchPause(ids:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"batchPause","kind":"identifier"},{"text":"(","kind":"text"},{"text":"ids","kind":"externalParam"},{"text":": [","kin
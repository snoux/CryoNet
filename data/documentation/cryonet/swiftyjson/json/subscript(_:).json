持嵌套路径访问"}]},{"type":"text","text":"和"},{"type":"strong","inlineContent":[{"text":"嵌套模型解析","type":"text"}]},{"type":"text","text":"。"}],"type":"paragraph"},{"anchor":"%E4%BD%BF%E7%94%A8%E7%A4%BA%E4%BE%8B","text":"使用示例","level":3,"type":"heading"},{"code":["\/\/ 简单字段","let title = json[\"title\"] ?? \"默认标题\"","let status = json[\"status\"] ?? 0","let price = json[\"price\"] ?? 0.0","let isActive = json[\"isActive\"] ?? false","","\/\/ 嵌套路径（支持点号分隔）","let userName = json[\"user.name\"] ?? \"未知用户\"","let userAge = json[\"user.profile.age\"] ?? 0","let city = json[\"data.address.city\"] ?? \"未知城市\"","","\/\/ 嵌套模型解析","struct NewModel: JSONParseable {","    let title: String","    let details: NewDetailsModel","    let comments: [CommentModel]","","    init?(json: JSON) {","        self.title = json[\"title\"] ?? \"默认标题\"","        ","        \/\/ 单个嵌套模型：方式1（使用 ?? 操作符）","        let defaultDetails = NewDetailsModel(json: JSON([\"title\": \"默认详情\"]))!","        self.details = json[\"details\"] ?? defaultDetails","        ","        \/\/ 单个嵌套模型：方式2（使用 toModel 方法，推荐）","        \/\/ self.details = json.toModel(NewDetailsModel.self, keyPath: \"details\") ?? defaultDetails","        ","        \/\/ 嵌套模型数组：使用 ?? 操作符","        self.comments = json[\"comments\"] ?? []","        ","        \/\/ 嵌套模型数组：使用 toModelArray 方法（推荐）","        \/\/ self.comments = json.toModelArray(CommentModel.self, keyPath: \"comments\")","    }","}"],"syntax":"swift","type":"codeListing"},{"content":[{"inlineContent":[{"text":"","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"此方法提供便捷语法，不影响现有的 ","type":"text"},{"type":"codeVoice","code":"string(_:defaultValue:)"},{"text":" 等方法","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"支持类型推断，编译器会自动推断返回类型","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"支持嵌套路径","type":"text"}]},{"type":"text","text":"：使用点号分隔的路径（如 "},{"type":"codeVoice","code":"\"user.name\""},{"type":"text","text":"），与现有方法行为一致"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"支持嵌套模型"}]},{"type":"text","text":"：如果类型遵循 "},{"type":"codeVoice","code":"JSONParseable"},{"type":"text","text":" 协议，会自动解析嵌套模型"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"如果 JSON 中不存在该键或类型不匹配，返回 nil，可使用 "},{"code":"??","type":"codeVoice"},{"type":"text","text":" 设置默认值"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"嵌套路径访问与 ","type":"text"},{"code":"json.string(\"user.name\", defaultValue:)","type":"codeVoice"},{"text":" 等现有方法行为完全一致","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"嵌套模型建议","type":"text"}]},{"type":"text","text":"：对于嵌套模型，推荐使用 "},{"code":"json.toModel(_:keyPath:)","type":"codeVoice"},{"type":"text","text":" 方法，更安全且支持可选值"}],"type":"paragraph"}]}],"type":"unorderedList"}],"style":"note","name":"Note","type":"aside"}],"kind":"content"}],"metadata":{"role":"symbol","fragments":[{"text":"subscript","kind":"keyword"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":") -> ","kind":"text"},{"text":"JSONValue","kind":"typeIdentifier","preciseIdentifier":"s:7CryoNet9JSONValueV"},{"text":"<","kind":"text"},{"text":"T","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftyJSON0B0V7CryoNetEyAD9JSONValueVyxGSScluip1TL_xmfp"},{"text":">","kind":"text"}],"modules":[{"relatedModules":["SwiftyJSON"],"name":"CryoNet"}],"extendedModule":"SwiftyJSON","externalID":"s:10SwiftyJSON0B0V7CryoNetEyAD9JSONValueVyxGSScluip","symbolKind":"subscript","roleHeading":"Instance Subscript","title":"subscript(_:)"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/SwiftyJSON\/JSON\/subscript(_:)"},"sections":[],"abstract":[{"type":"text","text":"类型推断
.0","let isActive = json[\"isActive\"] ?? false","","\/\/ 嵌套路径（支持点号分隔）","let userName = json[\"user.name\"] ?? \"未知用户\"","let userAge = json[\"user.profile.age\"] ?? 0","let city = json[\"data.address.city\"] ?? \"未知城市\"","","\/\/ 嵌套模型解析","struct NewModel: JSONParseable {","    let title: String","    let details: NewDetailsModel","    let comments: [CommentModel]","","    init?(json: JSON) {","        self.title = json[\"title\"] ?? \"默认标题\"","        ","        \/\/ 单个嵌套模型：方式1（使用 ?? 操作符）","        let defaultDetails = NewDetailsModel(json: JSON([\"title\": \"默认详情\"]))!","        self.details = json[\"details\"] ?? defaultDetails","        ","        \/\/ 单个嵌套模型：方式2（使用 toModel 方法，推荐）","        \/\/ self.details = json.toModel(NewDetailsModel.self, keyPath: \"details\") ?? defaultDetails","        ","        \/\/ 嵌套模型数组：使用 ?? 操作符","        self.comments = json[\"comments\"] ?? []","        ","        \/\/ 嵌套模型数组：使用 toModelArray 方法（推荐）","        \/\/ self.comments = json.toModelArray(CommentModel.self, keyPath: \"comments\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":""}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"此方法提供便捷语法，不影响现有的 ","type":"text"},{"code":"string(_:defaultValue:)","type":"codeVoice"},{"text":" 等方法","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"支持类型推断，编译器会自动推断返回类型"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"支持嵌套路径","type":"text"}],"type":"strong"},{"text":"：使用点号分隔的路径（如 ","type":"text"},{"code":"\"user.name\"","type":"codeVoice"},{"text":"），与现有方法行为一致","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"支持嵌套模型"}],"type":"strong"},{"text":"：如果类型遵循 ","type":"text"},{"type":"codeVoice","code":"JSONParseable"},{"text":" 协议，会自动解析嵌套模型","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"如果 JSON 中不存在该键或类型不匹配，返回 nil，可使用 ","type":"text"},{"type":"codeVoice","code":"??"},{"text":" 设置默认值","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"嵌套路径访问与 ","type":"text"},{"code":"json.string(\"user.name\", defaultValue:)","type":"codeVoice"},{"text":" 等现有方法行为完全一致","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"嵌套模型建议"}]},{"type":"text","text":"：对于嵌套模型，推荐使用 "},{"type":"codeVoice","code":"json.toModel(_:keyPath:)"},{"type":"text","text":" 方法，更安全且支持可选值"}],"type":"paragraph"}]}]}]}]}],"kind":"symbol","identifier":{"url":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/SwiftyJSON\/JSON\/subscript(_:)","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"metadata":{"fragments":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":">("},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:7CryoNet9JSONValueV","text":"JSONValue"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:10SwiftyJSON0B0V7CryoNetEyAD9JSONValueVyxGSScluip1TL_xmfp","text":"T"},{"kind":"text","text":">"}],"extendedModule":"SwiftyJSON","role":"symbol","title":"subscript(_:)","modules":[{"name":"CryoNet","relatedModules":["SwiftyJSON"]}],"roleHeading":"Instance Subscript","symbolKind":"subscript","externalID":"s:10SwiftyJSON0B0V7CryoNetEyAD9JSONValueVyxGSScluip"},"variants":[{"paths":["\/documentation\/cryonet\/swiftyjson\/json\/subscript(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"类型推断的下标访问，支持 ","type":"text"},{"code":"??","type":"codeVoice"},{"text":" 操作符设置默认值","type":"text"}],"hierarchy":{"paths":[["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet","doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/Sw
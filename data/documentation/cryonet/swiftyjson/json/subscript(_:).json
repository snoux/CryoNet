{"abstract":[{"type":"text","text":"类型推断的下标访问，支持 "},{"code":"??","type":"codeVoice"},{"type":"text","text":" 操作符设置默认值"}],"metadata":{"roleHeading":"Instance Subscript","title":"subscript(_:)","symbolKind":"subscript","extendedModule":"SwiftyJSON","modules":[{"name":"CryoNet","relatedModules":["SwiftyJSON"]}],"externalID":"s:10SwiftyJSON0B0V7CryoNetEyAD9JSONValueVyxGSScluip","role":"symbol","fragments":[{"text":"subscript","kind":"keyword"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":") -> ","kind":"text"},{"text":"JSONValue","kind":"typeIdentifier","preciseIdentifier":"s:7CryoNet9JSONValueV"},{"text":"<","kind":"text"},{"text":"T","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftyJSON0B0V7CryoNetEyAD9JSONValueVyxGSScluip1TL_xmfp"},{"text":">","kind":"text"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":">("},{"kind":"internalParam","text":"keyPath"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"JSONValue","identifier":"doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/JSONValue","preciseIdentifier":"s:7CryoNet9JSONValueV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"T","preciseIdentifier":"s:10SwiftyJSON0B0V7CryoNetEyAD9JSONValueVyxGSScluip1TL_xmfp"},{"kind":"text","text":"> { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"platforms":["iOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"keyPath","content":[{"type":"paragraph","inlineContent":[{"text":"JSON 键路径，支持嵌套路径（使用点号分隔，如 ","type":"text"},{"type":"codeVoice","code":"\"user.name\""},{"text":"）","type":"text"}]}]}]},{"kind":"content","content":[{"anchor":"return-value","level":2,"text":"Return Value","type":"heading"},{"inlineContent":[{"text":"","type":"text"},{"code":"JSONValue","type":"codeVoice"},{"text":" 包装器，支持类型推断和 ","type":"text"},{"type":"codeVoice","code":"??"},{"text":" 操作符","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"提供更简洁的语法来访问 JSON 值，支持类型推断和默认值。"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"支持嵌套路径访问"}]},{"type":"text","text":"和"},{"type":"strong","inlineContent":[{"text":"嵌套模型解析","type":"text"}]},{"type":"text","text":"。"}],"type":"paragraph"},{"text":"使用示例","anchor":"%E4%BD%BF%E7%94%A8%E7%A4%BA%E4%BE%8B","type":"heading","level":3},{"syntax":"swift","code":["\/\/ 简单字段","let title = json[\"title\"] ?? \"默认标题\"","let status = json[\"status\"] ?? 0","let price = json[\"price\"] ?? 0.0","let isActive = json[\"isActive\"] ?? false","","\/\/ 嵌套路径（支持点号分隔）","let userName = json[\"user.name\"] ?? \"未知用户\"","let userAge = json[\"user.profile.age\"] ?? 0","let city = json[\"data.address.city\"] ?? \"未知城市\"","","\/\/ 嵌套模型解析","struct NewModel: JSONParseable {","    let title: String","    let details: NewDetailsModel","    let comments: [CommentModel]","","    init?(json: JSON) {","        self.title = json[\"title\"] ?? \"默认标题\"","        ","        \/\/ 单个嵌套模型：方式1（使用 ?? 操作符）","        let defaultDetails = NewDetailsModel(json: JSON([\"title\": \"默认详情\"]))!","        self.details = json[\"details\"] ?? defaultDetails","        ","        \/\/ 单个嵌套模型：方式2（使用 toModel 方法，推荐）","        \/\/ self.details = json.toModel(NewDetailsModel.self, keyPath: \"details\") ?? defaultDetails","        ","        \/\/ 嵌套模型数组：使用 ?? 操作符","        self.comments = json[\"comments\"] ?? []","        ","        \/\/ 嵌套模型数组：使用 toModelArray 方法（推荐）","        \/\/ self.comments = json.toModelArray(CommentModel.self, keyPath: \"comments\")","    }","}"],"type":"codeListing"},{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"此方法提供便捷语法，不影响现有的 "},{"code":"string(_:defaultValue:)","type":"codeVoice"},{"type":"text","text":" 等方法"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"支持类型推断，编译器会自动推断返回类型","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"支持嵌套路径","type":"text"}]},{"type":"text","text":"：使用点号分隔的路径（如 "},{"type":"codeVoice","code":"\"user.name\""},{"type":"text","text":"），与现有方法行为一致"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"支持嵌套模型"}]},{"type":"text","text":"：如果类型遵循 "},{"type":"codeVoice","code":"JSONParseable"},{"type":"text","text":" 协议，会自动解析嵌套模型"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"如果 JSON 中不存在该键或类型不匹配，返回 nil，可使用 ","type":"text"},{"type":"codeVoice","code":"??"},{"text":" 设置默认值","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"嵌套路径访问与 "},{"type":"codeVoice","code":"json.string(\"user.name\", defaultValue:)"},{"type":"text","text":" 等现有方法行为完全一致"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"嵌套模型建议","type":"text"}],"type":"strong"},{"type":"text","text":"：对于嵌套模型，推荐使用 "},{"type":"codeVoice","code":"json.toModel(_:keyPath:)"},{"type":"text","text":" 方法，更安全且支持可选值"}]}]}]}]}]}],"hierarchy":{"paths":[["doc:\/\/cryonet.CryoNet\/documentation\/CryoNet","doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/SwiftyJSON","doc:\/\/cryonet.CryoNet\/documentation\/CryoNet\/SwiftyJSON\/JSON"]]},"kind":"symbol","sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/cryonet\/swiftyjson\/json\/subscript(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"do